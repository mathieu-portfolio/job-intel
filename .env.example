# Optional: only required when using the Adzuna source.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# AI ranking provider. Supported values: openai, ollama, mock.
JOB_INTEL_LLM_PROVIDER=openai

# Required for OpenAI ranking.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required for Ollama ranking.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3
